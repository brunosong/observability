{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU Usage (JVM process & system)",
      "description": "process_cpu_usage = JVM process CPU as fraction of one core normalized to total cores. system_cpu_usage = host/container system CPU. cpu-spike burst pushes process line toward 1.0.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "id": 2,
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 10 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_cpu_usage{application=\"$application\", instance=\"$instance\"}",
          "legendFormat": "process",
          "editorMode": "code",
          "range": true
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "system_cpu_usage{application=\"$application\", instance=\"$instance\"}",
          "legendFormat": "system",
          "editorMode": "code",
          "range": true
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "system_load_average_1m{application=\"$application\", instance=\"$instance\"} / system_cpu_count{application=\"$application\", instance=\"$instance\"}",
          "legendFormat": "load1m / cpus",
          "editorMode": "code",
          "range": true
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "max", "mean"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "cpu (0..1 = 0..100%)",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "orange", "value": 0.8 },
              { "color": "red",    "value": 0.95 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "process" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } },
              { "id": "custom.lineWidth", "value": 3 },
              { "id": "custom.fillOpacity", "value": 20 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "system" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "custom.fillOpacity", "value": 5 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "load1m / cpus" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [4, 4] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "Endpoint Request Rate (correlate spikes ↔ traffic)",
      "description": "Per-URI requests/sec. Watch /api/*/cpu-spike and /api/*/db-lock spikes overlay with CPU/pool panels.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "id": 3,
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 19 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{application=\"$application\", instance=\"$instance\", uri=~\".*/api/.*\"}[1m]))",
          "legendFormat": "{{uri}}",
          "editorMode": "code",
          "range": true
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "max"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 5,
            "spanNulls": true,
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*cpu-spike.*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } },
              { "id": "custom.lineWidth", "value": 3 }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*db-lock.*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineWidth", "value": 3 }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "HikariCP Pool State",
      "description": "Idle/Active/Pending/Total connections with Min/Max reference lines. Pending > 0 indicates pool starvation.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "id": 1,
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_idle{application=\"$application\", instance=\"$instance\"}",
          "legendFormat": "idle",
          "editorMode": "code",
          "range": true
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_active{application=\"$application\", instance=\"$instance\"}",
          "legendFormat": "active",
          "editorMode": "code",
          "range": true
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_pending{application=\"$application\", instance=\"$instance\"}",
          "legendFormat": "pending",
          "editorMode": "code",
          "range": true
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections{application=\"$application\", instance=\"$instance\"}",
          "legendFormat": "total",
          "editorMode": "code",
          "range": true
        },
        {
          "refId": "E",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_min{application=\"$application\", instance=\"$instance\"}",
          "legendFormat": "min",
          "editorMode": "code",
          "range": true
        },
        {
          "refId": "F",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_max{application=\"$application\", instance=\"$instance\"}",
          "legendFormat": "max",
          "editorMode": "code",
          "range": true
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "max", "min"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "none",
            "spanNulls": true,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "connections",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "tooltip": false, "viz": false, "legend": false }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red",    "value": 2 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "idle" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "active" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "custom.fillOpacity", "value": 15 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pending" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineWidth", "value": 3 },
              { "id": "custom.fillOpacity", "value": 30 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "total" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "max" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "gray" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "min" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "gray" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.lineStyle", "value": { "fill": "dot", "dash": [2, 4] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["hikaricp", "spring-boot"],
